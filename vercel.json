{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/outputs/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/outputs/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/outputs/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/outputs/styles.css"
    },
    {
      "source": "/sw.js",
      "destination": "/outputs/sw.js"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/outputs/manifest.webmanifest"
    },
    {
      "source": "/icon.svg",
      "destination": "/outputs/icon.svg"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
